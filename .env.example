# ==================== FREE BACKEND CONFIGURATION ====================

# ==================== SUPABASE (FREE - 500MB, 50K requests/month) ====================
# Website: https://supabase.com
# Steps:
# 1. Create free account
# 2. Create new project
# 3. Go to Settings > API
# 4. Copy URL and anon key below

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==================== CLOUDINARY (FREE - 25GB storage, 25GB bandwidth/month) ====================
# Website: https://cloudinary.com
# Steps:
# 1. Create free account
# 2. Go to Dashboard
# 3. Copy Cloud Name below
# 4. Go to Settings > Upload
# 5. Add Upload Preset (unsigned)

VITE_CLOUDINARY_CLOUD_NAME=dikwxvzxn
VITE_CLOUDINARY_UPLOAD_PRESET=porfolio

# ==================== SETUP INSTRUCTIONS ====================
# 1. Copy this file and rename to .env
# 2. Replace all YOUR_* values with actual credentials
# 3. Restart dev server: npm run dev

# ==================== DATABASE TABLES (Run in Supabase SQL Editor) ====================
# Copy and run the SQL from: supabase/migrations/001_initial_schema.sql
# This creates: posts, subscribers, users tables

# ==================== FEATURES ENABLED ====================
# ✅ Blog CRUD with Supabase
# ✅ Real-time sync across tabs
# ✅ Image upload (Cloudinary or local fallback)
# ✅ Newsletter subscription
# ✅ Search functionality
# ✅ Admin authentication
# ✅ Dark/Light mode
# ✅ Animated galaxy background

# ==================== FREE TIER LIMITS ====================
# Supabase: 500MB storage, 5GB bandwidth, 50K requests/month
# Cloudinary: 25GB storage, 25GB bandwidth, 25K transformations/month

# ==================== EMAILJS (FREE - 200 emails/month) ====================
# Website: https://www.emailjs.com
# Steps:
# 1. Create free account
# 2. Add Email Service (Gmail, Outlook, etc.)
# 3. Create Email Template
# 4. Get Public Key from Account > API Keys

VITE_EMAILJS_SERVICE_ID=service_8glnpf6
VITE_EMAILJS_TEMPLATE_ID=template_bwcnm9v
VITE_EMAILJS_PUBLIC_KEY=-ziYnFIG2ECAQy-2q
VITE_EMAILJS_NEWSLETTER_TEMPLATE_ID=template_hnkgdq8

# ==================== OPENAI AI CHATBOT (FREE - Limited requests) ====================
# Website: https://platform.openai.com/
# Steps:
# 1. Create free account
# 2. Go to API Keys
# 3. Create new secret key
# 4. Copy the key (starts with sk-)

VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_OPENAI_MODEL=gpt-3.5-turbo
